      "counting     (vocab=32): [21, 19, 19, 26, 10, 10, 10, 10, 10, 10, 10, 29, 7, 7, 7, 7, 7, 7, 7, 7, 7, 7, 24, 5]\n",
      "mirror       (vocab=25): [6, 5, 1, 19, 21, 8, 15, 2, 2, 21, 4, 24, 4, 21, 2, 2, 15, 8, 21, 19, 1, 5, 6]\n"
